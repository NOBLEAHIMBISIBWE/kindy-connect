# Kindy Connect Environment Variables
 
# Application
VITE_APP_NAME=Little Stars
VITE_APP_URL=http://localhost:3000

# SMS Notification Service (for parent notifications)
VITE_SMS_API_KEY=your_sms_api_key_here
VITE_SMS_API_URL=https://api.sms-provider.com/send

# Email Notification Service (for parent notifications)
VITE_EMAIL_API_KEY=your_email_api_key_here
VITE_EMAIL_FROM=noreply@littlestars.edu

# Database (when migrating from mock store)
# DATABASE_URL=your_database_connection_string

# Authentication (when implementing real auth)
# VITE_AUTH_SECRET=your_auth_secret_here

# Environment
NODE_ENV=development
